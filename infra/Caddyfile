{
	admin off
	http_port 8080
	https_port 8443
	servers {
		protocols h1 h2
	}
}

www.{$CROSSPATCH_SITE_ADDRESS:localhost} {
	redir https://{$CROSSPATCH_SITE_ADDRESS:localhost}{uri} permanent
}

{$CROSSPATCH_SITE_ADDRESS:localhost} {
	encode zstd gzip

	header {
		-Server
		Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Referrer-Policy "no-referrer"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}

	@judgeAuthorized {
		path /mcp/judge /mcp/judge/*
		header Authorization "Bearer *"
	}
	handle @judgeAuthorized {
		uri replace /mcp/judge /mcp
		reverse_proxy judge-mcp:8013 {
			header_up -X-Forwarded-User
			header_up X-CrossPatch-Proxy judge
		}
	}

	@judgeUnauthorized path /mcp/judge /mcp/judge/*
	handle @judgeUnauthorized {
		respond `{ "error": "judge bearer authentication required"}` 401 {
			close
		}
	}

	handle /healthz {
		reverse_proxy api:8000
	}

	handle /api/* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
