ate_bb7be1fae4f647ed9c62a32d98afee13","patch_sha256":"45885a9e5e06a8496997745188c7f05e7b72335df6ad928607d23a510905ecf7","patch_defense":"The remanded diff has corrected unified-hunk line offsets and counts. The receipt insert is the transactional claim; only its successful RETURNING path creates an outbox job, while a conflict reads the committed receipt to return duplicate or payload-mismatch status.","evidence_ids":["ev_a9983cedf9ca4ea8b0aebb1d968e1a2d","ev_5bb941f4d48a4ae58e9c34b83730862e"],"test_intentions":[{"catalog_id":"victim.duplicate-race.candidate","purpose":"Verify concurrent identical webhook requests produce exactly one receipt, one outbox job, and one delivery."}]},{"run_id":"run_318253981fde4563840f1e3958735047","model":"gpt-5.6-luna","effort":"low","escalation_count":0,"phase":"remand-challenge","output_sha256":"2f322dd505e8f150b56a8832d9bd0db59c466180cab33a348458549da0c1fe16","semantic_sha256":"093dca7bd0f2ada8d65930db6da99491ca6028bc1eab2dcd1ca86ff8464500cc","created_at":"2026-07-14T09:04:23.215717Z","sanitization_tags":[],"kind":"PROSECUTOR","seat":"Prosecutor","outcome":"SUPPORTED_RIVAL","rival_mechanism":"WORKER_RETRY_DUPLICATION","counterexample_ids":["victim.worker-retry"],"test_ids":["victim.worker-retry"],"evidence_ids":["ev_9d6c7ad9f9e740d5a0ee27d43b877ece","ev_a9983cedf9ca4ea8b0aebb1d968e1a2d"]}],"warrants":[],"artifacts":{"evidence":[{"classification":"UNTRUSTED_EVIDENCE","id":"ev_a9983cedf9ca4ea8b0aebb1d968e1a2d","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","provenance":"deterministic webhook race reproduction","kind":"test_output","sanitized_sha256":"ae6bb4570c7ed9af3a9feb59163c57de244d9f1e98c3b930536ef9f322fc4586","captured_at":"2026-07-14T09:02:56.253363Z","text":"{\"counts\":{\"deliveries\":2,\"jobs\":2,\"receipts\":1},\"diagnostics\":[\"observed 2 externally blocked outbox insert(s)\",\"HTTP statuses: (202, 202)\",\"persisted counts: {'receipts': 1, 'jobs': 2, 'deliveries': 2}\"],\"lock_state_reached\":true,\"outcome\":\"FAILED\",\"response_statuses\":[202,202]}","tags":[]},{"classification":"UNTRUSTED_EVIDENCE","id":"ev_ee810b096d0c45a58d87e558c9acdb4d","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","provenance":"bundled incident source: victim/src/victim/app.py","kind":"source","sanitized_sha256":"ab213b68be6a9ad6dedbc679f56ffd543d838220fb676aaf8fd033f10740dcbe","captured_at":"2026-07-14T09:02:56.279942Z","text":"[PRIVATE_AUTHORITY_MATERIAL_REDACTED]","tags":["PRIVATE_AUTHORITY_MATERIAL_REDACTED"]},{"classification":"UNTRUSTED_EVIDENCE","id":"ev_5bb941f4d48a4ae58e9c34b83730862e","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","provenance":"bundled incident source: victim/src/victim/db.py","kind":"source","sanitized_sha256":"71de82454bdb34e972a179191234b01bd0db9102905fafd2ec9f9a015aae8beb","captured_at":"2026-07-14T09:02:56.291010Z","text":"\"\"\"PostgreSQL persistence for the webhook victim.\n\n`accept_vulnerable` intentionally contains the incident's check-then-insert race:\nthe outbox row is created before the receipt is published.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Iterator\nfrom contextlib import contextmanager\nfrom dataclasses import dataclass\nfrom enum import StrEnum\nfrom pathlib import Path\nfrom typing import Any\n\nimport psycopg\nfrom psycopg.rows import dict_row\nfrom psycopg.types.json import Jsonb\n\n\nclass IngestDisposition(StrEnum):\n    ACCEPTED = \"ACCEPTED\"\n    DUPLICATE = \"DUPLICATE\"\n    PAYLOAD_MISMATCH = \"PAYLOAD_MISMATCH\"\n\n\n@dataclass(frozen=True, slots=True)\nclass WebhookEvent:\n    provider: str\n    event_id: str\n    payload: dict[str, Any]\n    payload_sha256: str\n\n\nclass Database:\n    def __init__(self, dsn: str) -> None:\n        self.dsn = dsn\n\n    def connect(self, *, autocommit: bool = False):\n        return psycopg.connect(self.dsn, autocommit=autocommit, row_factory=dict_row)\n\n    def initialize(self) -> None:\n        root = Path(__file__).parents[3]\n        schema = (root / \"infra/postgres/victim-init.sql\").read_text(encoding=\"utf-8\")\n        with self.connect(autocommit=True) as connection:\n            connection.execute(schema)\n\n    def reset(self) -> None:\n        with self.connect(autocommit=True) as connection:\n            connection.execute(\n                \"TRUNCATE deliveries, outbox_jobs, webhook_receipts RESTART IDENTITY CASCADE\"\n            )\n\n    def clear_event(self, provider: str, event_id: str) -> None:\n        with self.connect() as connection, connection.transaction():\n            connection.execute(\n                \"DELETE FROM deliveries WHERE provider = %s AND event_id = %s\",\n                (provider, event_id),\n            )\n            connection.execute(\n                \"DELETE FROM outbox_jobs WHERE provider = %s AND event_id = %s\",\n                (provider, event_id),\n            )\n            connection.execute(\n                \"DELETE FROM webhook_receipts WHERE provider = %s AND event_id = %s\",\n                (provider, event_id),\n            )\n\n    def accept_vulnerable(self, event: WebhookEvent) -> IngestDisposition:\n        with self.connect() as connection, connection.transaction():\n            existing = connection.execute(\n                \"\"\"\n                SELECT payload_sha256\n                  FROM webhook_receipts\n                 WHERE provider = %s AND event_id = %s\n                \"\"\",\n                (event.provider, event.event_id),\n            ).fetchone()\n            if existing is not None:\n                if existing[\"payload_sha256\"].strip() != event.payload_sha256:\n                    return IngestDisposition.PAYLOAD_MISMATCH\n                return IngestDisposition.DUPLICATE\n\n            # Deliberately vulnerable ordering: two transactions can both pass\n            # the check and enqueue work before either publishes its receipt.\n            connection.execute(\n                \"\"\"\n                INSERT INTO outbox_jobs (provider, event_id, payload, payload_sha256)\n                VALUES (%s, %s, %s, %s)\n                \"\"\",\n                (\n                    event.provider,\n                    event.event_id,\n                    Jsonb(event.payload),\n                    event.payload_sha256,\n                ),\n            )\n            connection.execute(\n                \"\"\"\n                INSERT INTO webhook_receipts (provider, event_id, payload_sha256)\n                VALUES (%s, %s, %s)\n                ON CONFLICT (provider, event_id) DO NOTHING\n                \"\"\",\n                (event.provider, event.event_id, event.payload_sha256),\n            )\n            return IngestDisposition.ACCEPTED\n\n    def counts(self, *, provider: str, event_id: str | None = None) -> dict[str, int]:\n        predicate = \"provider = %s\"\n        parameters: tuple[str, ...] = (provider,)\n        if event_id is not None:\n            predicate += \" AND event_id = %s\"\n            parameters += (event_id,)\n        with self.connect(autocommit=True) as connection:\n            return {\n                \"receipts\": connection.execute(\n                    f\"SELECT count(*) AS count FROM webhook_receipts WHERE {predicate}\",\n                    parameters,\n                ).fetchone()[\"count\"],\n                \"jobs\": connection.execute(\n                    f\"SELECT count(*) AS count FROM outbox_jobs WHERE {predicate}\", parameters\n                ).fetchone()[\"count\"],\n                \"deliveries\": connection.execute(\n                    f\"SELECT count(*) AS count FROM deliveries WHERE {predicate}\", parameters\n                ).fetchone()[\"count\"],\n            }\n\n    @contextmanager\n    def transaction(self) -> Iterator[psycopg.Connection]:\n        with self.connect() as connection, connection.transaction():\n            yield connection\n","tags":[]},{"classification":"UNTRUSTED_EVIDENCE","id":"ev_572e129dddae44de84f0b0f7af8c00f6","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","provenance":"bundled incident source: victim/src/victim/webhooks.py","kind":"source","sanitized_sha256":"06562aaba75114ece9102cf584e9ac64a944b43252f74849b72407bd8cefb977","captured_at":"2026-07-14T09:02:56.298064Z","text":"\"\"\"Signed webhook parsing and business response mapping.\"\"\"\n\nfrom __future__ import annotations\n\nimport hashlib\n\nfrom pydantic import BaseModel, ConfigDict, Field\n\nfrom victim.db import Database, IngestDisposition, WebhookEvent\n\n\nclass OrderPaid(BaseModel):\n    model_config = ConfigDict(extra=\"forbid\", strict=True)\n\n    provider: str = Field(min_length=1, max_length=80, pattern=r\"^[a-z0-9-]+$\")\n    event_id: str = Field(min_length=1, max_length=160)\n    order_id: str = Field(min_length=1, max_length=160)\n    amount_cents: int = Field(ge=0)\n\n\ndef ingest(database: Database, body: bytes) -> IngestDisposition:\n    payload = OrderPaid.model_validate_json(body)\n    return database.accept_vulnerable(\n        WebhookEvent(\n            provider=payload.provider,\n            event_id=payload.event_id,\n            payload=payload.model_dump(mode=\"json\"),\n            payload_sha256=hashlib.sha256(body).hexdigest(),\n        )\n    )\n","tags":[]},{"classification":"UNTRUSTED_EVIDENCE","id":"ev_9d6c7ad9f9e740d5a0ee27d43b877ece","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","provenance":"bundled incident source: victim/src/victim/worker.py","kind":"source","sanitized_sha256":"711fc317c6ebbec70f9fe67a5e9df4f2f9a8838e0832150ac953bbacba06d9b6","captured_at":"2026-07-14T09:02:56.305210Z","text":"\"\"\"Transactional outbox consumer with bounded retry state.\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom dataclasses import dataclass\nfrom typing import Any\n\nfrom victim.db import Database\n\n\n@dataclass(frozen=True, slots=True)\nclass JobResult:\n    job_id: int\n    state: str\n    attempt_count: int\n\n\nclass DeliveryWorker:\n    def __init__(\n        self,\n        database: Database,\n        *,\n        deliver: Callable[[dict[str, Any]], None] | None = None,\n    ) -> None:\n        self.database = database\n        self.deliver = deliver or (lambda _job: None)\n\n    def run_once(self) -> JobResult | None:\n        with self.database.transaction() as connection:\n            job = connection.execute(\n                \"\"\"\n                SELECT id, provider, event_id, payload_sha256, attempt_count, max_attempts\n                  FROM outbox_jobs\n                 WHERE state = 'PENDING'\n                 ORDER BY created_at, id\n                 FOR UPDATE SKIP LOCKED\n                 LIMIT 1\n                \"\"\"\n            ).fetchone()\n            if job is None:\n                return None\n            attempt = job[\"attempt_count\"] + 1\n            connection.execute(\n                \"UPDATE outbox_jobs SET state = 'PROCESSING', attempt_count = %s WHERE id = %s\",\n                (attempt, job[\"id\"]),\n            )\n            try:\n                self.deliver(dict(job))\n            except Exception as error:\n                state = \"DEAD\" if attempt >= job[\"max_attempts\"] else \"PENDING\"\n                connection.execute(\n                    \"UPDATE outbox_jobs SET state = %s, last_error = %s WHERE id = %s\",\n                    (state, str(error)[:500], job[\"id\"]),\n                )\n                return JobResult(job_id=job[\"id\"], state=state, attempt_count=attempt)\n\n            connection.execute(\n                \"\"\"\n                INSERT INTO deliveries (job_id, provider, event_id, payload_sha256)\n                VALUES (%s, %s, %s, %s)\n                \"\"\",\n                (job[\"id\"], job[\"provider\"], job[\"event_id\"], job[\"payload_sha256\"]),\n            )\n            connection.execute(\n                \"\"\"\n                UPDATE outbox_jobs\n                   SET state = 'COMPLETED', completed_at = CURRENT_TIMESTAMP, last_error = NULL\n                 WHERE id = %s\n                \"\"\",\n                (job[\"id\"],),\n            )\n            return JobResult(job_id=job[\"id\"], state=\"COMPLETED\", attempt_count=attempt)\n\n    def drain(self, *, limit: int = 1000) -> int:\n        completed = 0\n        for _ in range(limit):\n            result = self.run_once()\n            if result is None:\n                break\n            completed += result.state == \"COMPLETED\"\n        return completed\n","tags":[]}],"diff":{"classification":"UNTRUSTED_EVIDENCE","incident_id":"inc_de59664e3e944b1c9bd3b87a55cac99b","candidate_id":"candidate_bb7be1fae4f647ed9c62a32d98afee13","patch_sha256":"45885a9e5e06a8496997745188c7f05e7b72335df6ad928607d23a510905ecf7","text":"diff --git a/victim/src/victim/db.py b/victim/src/victim/db.py\nindex 71de824..f3e8a9c 100644\n--- a/victim/src/victim/db.py\n+++ b/victim/src/victim/db.py\n@@ -71,37 +71,37 @@ class Database:\n     def accept_vulnerable(self, event: WebhookEvent) -> IngestDisposition:\n         with self.connect() as connection, connection.transaction():\n-            existing = connection.execute(\n+            receipt = connection.execute(\n                 \"\"\"\n-                SELECT payload_sha256\n-                  FROM webhook_receipts\n-                 WHERE provider = %s AND event_id = %s\n+                INSERT INTO webhook_receipts (provider, event_id, payload_sha256)\n+                VALUES (%s, %s, %s)\n+                ON CONFLICT (provider, event_id) DO NOTHING\n+                RETURNING payload_sha256\n                 \"\"\",\n-                (event.provider, event.event_id),\n+                (event.provider, event.event_id, event.payload_sha256),\n             ).fetchone()\n-            if existing is not None:\n-                if existing[\"payload_sha256\"].strip() != event.payload_sha256:\n+            if receipt is None:\n+                existing = connection.execute(\n+                    \"\"\"\n+                    SELECT payload_sha256\n+                      FROM webhook_receipts\n+                     WHERE provider = %s AND event_id = %s\n+                    \"\"\",\n+                    (event.provider, event.event_id),\n+                ).fetchone()\n+                if existing[\"payload_sha256\"].strip() != event.payload_sha256:\n                     return IngestDisposition.PAYLOAD_MISMATCH\n                 return IngestDisposition.DUPLICATE\n \n-            # Deliberately vulnerable ordering: two transactions can both pass\n-            # the check and enqueue work before either publishes its receipt.\n             connection.execute(\n                 \"\"\"\n                 INSERT INTO outbox_jobs (provider, event_id, payload, payload_sha256)\n@@ -102,13 +102,6 @@ class Database:\n                     event.payload_sha256,\n                 ),\n             )\n-            connection.execute(\n-                \"\"\"\n-                INSERT INTO webhook_receipts (provider, event_id, payload_sha256)\n-                VALUES (%s, %s, %s)\n-                ON CONFLICT (provider, event_id) DO NOTHING\n-                \"\"\",\n-                (event.provider, event.event_id, event.payload_sha256),\n-            )\n             return IngestDisposition.ACCEPTED\n","sanitized_sha256":"45885a9e5e06a8496997745188c7f05e7b72335df6ad928607d23a510905ecf7","tags":[],"created_at":"2026-07-14T09:04:19.541689Z"},"tests":[],"warrant":null},"pending_warrant":null}