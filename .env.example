# Required by the OpenAI Agents SDK. Supply this only in the runtime environment.
OPENAI_API_KEY=

# The only supported Agents SDK transport is the Responses API.
CROSSPATCH_OPENAI_API=responses

# Hosted deployments must set this to 1. Release mode rejects the checked-in
# local-only defaults and low-entropy runtime credentials at service startup.
CROSSPATCH_RELEASE_MODE=0

# Local Compose has non-production fallback values so judges can inspect the
# stack. Hosted deployments must replace every value below with an independent
# random secret of at least 32 bytes and keep matching zone keys identical
# between the API and that zone's MCP service.
CROSSPATCH_POSTGRES_PASSWORD=
CROSSPATCH_API_POSTGRES_PASSWORD=
CROSSPATCH_BROKER_POSTGRES_PASSWORD=
CROSSPATCH_EVIDENCE_POSTGRES_PASSWORD=
CROSSPATCH_JUDGE_POSTGRES_PASSWORD=
CROSSPATCH_VERIFICATION_POSTGRES_PASSWORD=
CROSSPATCH_VICTIM_POSTGRES_ADMIN_PASSWORD=
CROSSPATCH_VICTIM_APP_PASSWORD=
CROSSPATCH_VICTIM_CANDIDATE_PASSWORD=
CROSSPATCH_VICTIM_WORKER_PASSWORD=
CROSSPATCH_VICTIM_ORACLE_PASSWORD=
CROSSPATCH_VICTIM_SCOPE_PASSWORD=
CROSSPATCH_OPERATOR_TOKEN=
CROSSPATCH_READER_TOKEN=
CROSSPATCH_APPROVER_TOKEN=
CROSSPATCH_APPROVER_CSRF_TOKEN=
CROSSPATCH_APPROVER_STEP_UP_TOKEN=
CROSSPATCH_APPROVAL_MAC_KEY=
CROSSPATCH_EXPORT_SIGNING_SEED=
CROSSPATCH_EVIDENCE_MCP_SIGNING_SECRET=
CROSSPATCH_BROKER_MCP_SIGNING_SECRET=
CROSSPATCH_JUDGE_MCP_SIGNING_SECRET=
CROSSPATCH_RUNNER_TOKEN=
CROSSPATCH_CANDIDATE_EXECUTOR_TOKEN=
CROSSPATCH_VICTIM_WEBHOOK_SECRET=

# Host-only path to an owner-readable base64 key used to authenticate backup
# manifests. Generate it with `openssl rand -base64 48` and chmod it 0600.
CROSSPATCH_BACKUP_AUTH_KEY_FILE=

# Hosted release mode requires the measured lowercase SHA-256 image/runtime
# identities used by warrant construction; placeholder or development digests
# are refused.
CROSSPATCH_RUNNER_DIGEST=
CROSSPATCH_ENVIRONMENT_DIGEST=

# Set these for hosted TLS. The local defaults remain https://localhost and an
# internal Caddy certificate.
CROSSPATCH_PUBLIC_URL=
CROSSPATCH_SITE_ADDRESS=
CROSSPATCH_ALLOWED_ORIGINS=https://localhost

# Development is loopback-only. A hosted release must explicitly set 0.0.0.0
# only after enabling release mode and replacing every development credential.
CROSSPATCH_BIND_ADDRESS=127.0.0.1
CROSSPATCH_HTTP_PORT=80
CROSSPATCH_HTTPS_PORT=443

# Must remain at or after 2026-08-13T07:00:00Z.
CROSSPATCH_JUDGE_TOKEN_EXPIRES_AT=2026-09-01T07:00:00Z
# Default Judge access is publication-bounded and browses every explicitly
# published case. Set to 1 only for optional single-incident tokens.
CROSSPATCH_JUDGE_INCIDENT_SCOPED=0

# Live-trial API credentials share this one cumulative model-spend ceiling.
# Issuing additional credentials never multiplies it. The request window is
# enforced independently per credential.
CROSSPATCH_LIVE_TRIAL_GLOBAL_BUDGET_USD=20
CROSSPATCH_LIVE_TRIAL_RUN_RESERVATION_USD=4
CROSSPATCH_LIVE_TRIAL_REQUESTS_PER_WINDOW=3
CROSSPATCH_LIVE_TRIAL_WINDOW_SECONDS=3600

# No judge bearer is created at startup. Issue one only through authenticated
# `uv run crosspatch judge-token rotate`; plaintext is returned once and only
# its persistent hash is retained.
